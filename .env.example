# ─────────────────────────────────────────────────────────────────────
# Client-side Vite variables. These are BUNDLED INTO THE BROWSER app
# and must never contain secrets. Use only keys that are safe to expose
# publicly (Supabase anon / publishable keys are designed for this).
# ─────────────────────────────────────────────────────────────────────
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-or-publishable-key"

# Legacy — kept for backwards compatibility with any scripts reading
# these names. Safe to copy the same values as the VITE_* equivalents.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-or-publishable-key"

# ─────────────────────────────────────────────────────────────────────
# Edge-function secrets (server-side only — NOT prefixed with VITE_).
# Configure these in Supabase Dashboard → Settings → Edge Functions.
# Do NOT put them in this file for local dev unless you are running
# functions locally with `supabase functions serve`.
# ─────────────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY="service-role-key-never-commit"
# SUPABASE_ANON_KEY="anon-key"
# BLAND_WEBHOOK_SECRET="random-long-string-shared-with-bland.ai-webhook-url"
# SEND_EMAIL_HOOK_SECRET="secret-from-supabase-auth-hooks-config"
# RESEND_API_KEY="..."
# OPENAI_API_KEY="..."
# BLAND_AI_API_KEY="..."

# ─────────────────────────────────────────────────────────────────────
# Stripe — central billing hub (Autocurb Suite)
# ─────────────────────────────────────────────────────────────────────
# Secret key used by every billing-* edge function + stripe-webhook.
# STRIPE_SECRET_KEY="sk_live_..."
# Signing secret for the single webhook endpoint at /functions/v1/stripe-webhook.
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Publishable key — not read by code today, kept here for any future
# client-side Stripe.js usage (e.g. payment element embeds).
# STRIPE_PUBLISHABLE_KEY="pk_live_..."
